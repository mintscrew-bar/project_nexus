NODE_ENV=production

# Public URLs
APP_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example
NEXTAUTH_URL=https://your-domain.example
NEXT_PUBLIC_API_URL=https://your-domain.example

# Host ports exposed by docker-compose.prod.yml.
# If you put Nginx/Caddy in front, keep these bound to localhost at the proxy layer.
WEB_HOST_PORT=3000
API_HOST_PORT=4000
UPTIME_KUMA_HOST_PORT=3001

# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:change-me-long-random-password@postgres:5432/nexus?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Auth secrets
JWT_ACCESS_SECRET=change-me-openssl-rand-base64-32
JWT_REFRESH_SECRET=change-me-openssl-rand-base64-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-me-openssl-rand-base64-32

# OAuth / Riot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://your-domain.example/api/auth/discord/callback
DISCORD_LINK_CALLBACK_URL=https://your-domain.example/api/auth/discord/link/callback
DISCORD_GUILD_CALLBACK_URL=https://your-domain.example/api/discord/guild-link/callback
RIOT_API_KEY=

# Optional Discord automation
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_NOTIFICATION_CHANNEL_ID=
ADMIN_ALERT_DISCORD_GUILD_ID=
ADMIN_ALERT_DISCORD_CHANNEL_ID=
ADMIN_ALERT_DISCORD_APPROVAL_CHANNEL_ID=
ADMIN_ALERT_DISCORD_REPORT_CHANNEL_ID=
ADMIN_ALERT_DISCORD_APPEAL_CHANNEL_ID=
ADMIN_ALERT_DISCORD_OPERATION_CHANNEL_ID=
ADMIN_ALERT_DISCORD_SECURITY_CHANNEL_ID=
DISCORD_MEMBER_ROLE_ID=
DISCORD_MEMBER_ROLE_NAME=인증됨
DISCORD_MAIN_LINE_ROLE_PREFIX=주라인-
DISCORD_SUB_LINE_ROLE_PREFIX=부라인-
DISCORD_TIER_ROLE_PREFIX=티어-
DISCORD_LOBBY_CHANNEL_NAME=내전 대기실
DISCORD_CAPTAIN_ROLE_NAME=팀장

# Lab raw match cache cleanup. Keep false until ranked/normal/aram recompute is fully normalized.
RIOT_MATCH_CACHE_CLEANUP_ENABLED=false
RIOT_MATCH_CACHE_TTL_DAYS=14

# Upload storage. Use "r2" after creating a Cloudflare R2 bucket and public/custom domain.
UPLOAD_DRIVER=local
UPLOAD_PUBLIC_BASE_URL=
NEXT_PUBLIC_UPLOADS_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional override. Defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=

# Cloudflare Tunnel — only needed when running with --profile tunnel.
# Get from Cloudflare Zero Trust → Networks → Tunnels → Docker tab.
CLOUDFLARE_TUNNEL_TOKEN=
