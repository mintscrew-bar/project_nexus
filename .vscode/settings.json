{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "prisma.pinToPrisma6": true,

  "todo-tree.general.tags": ["TODO", "FIXME", "HACK", "NOTE", "BUG", "[ ]", "[x]"],
  "todo-tree.general.tagGroups": {
    "TODO": ["TODO", "[ ]"],
    "DONE": ["[x]"]
  },
  "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|^\\s*\\*|^)\\s*($TAGS)|^\\s*-\\s*\\[[x ]\\])",
  "todo-tree.regex.regexCaseSensitive": false,
  "todo-tree.filtering.includeGlobs": ["**/*.md", "**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
  "todo-tree.filtering.excludeGlobs": ["**/node_modules/**", "**/.next/**", "**/dist/**"],
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#fff",
    "background": "#f59e0b",
    "icon": "check",
    "type": "text"
  },
  "todo-tree.highlights.customHighlight": {
    "[ ]": {
      "icon": "checklist",
      "background": "#3b82f6",
      "foreground": "#fff"
    },
    "[x]": {
      "icon": "check",
      "background": "#22c55e",
      "foreground": "#fff",
      "gutterIcon": true
    },
    "TODO": {
      "icon": "tasklist",
      "background": "#f59e0b",
      "foreground": "#fff"
    },
    "FIXME": {
      "icon": "alert",
      "background": "#ef4444",
      "foreground": "#fff"
    }
  }
}
