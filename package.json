{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @nexus/database studio",
    "compose:up": "docker compose -f docker-compose.dev.yml up --build",
    "compose:down": "docker compose -f docker-compose.dev.yml down --remove-orphans",
    "compose:logs:api": "docker compose -f docker-compose.dev.yml logs --tail=120 api",
    "compose:logs:web": "docker compose -f docker-compose.dev.yml logs --tail=120 web",
    "compose:prod:config": "docker compose --env-file .env.production -f docker-compose.prod.yml config",
    "compose:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "compose:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "compose:prod:logs:api": "docker compose --env-file .env.production -f docker-compose.prod.yml logs --tail=120 api",
    "compose:prod:logs:web": "docker compose --env-file .env.production -f docker-compose.prod.yml logs --tail=120 web"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.14",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.1",
      "follow-redirects": "^1.16.0",
      "postcss": "^8.5.10",
      "qs": "^6.15.2",
      "socket.io-parser": "^4.2.6",
      "ws": "^8.20.1",
      "diff": "^4.0.4",
      "basic-ftp": "^5.3.1",
      "systeminformation": "^5.31.6",
      "ip-address": "^10.2.0",
      "fast-uri": "^3.1.2",
      "flatted": "^3.4.2",
      "brace-expansion": "^5.0.6",
      "minimatch@<3.1.4": "^3.1.5",
      "ajv@<7": "^6.14.0",
      "ajv@>=7.0.0-alpha.0 <9": "^8.20.0",
      "picomatch@<3": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": "^8.4.2"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
