{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @nexus/database studio",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --remove-orphans",
    "compose:logs:api": "docker compose logs --tail=120 api",
    "compose:logs:web": "docker compose logs --tail=120 web"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
