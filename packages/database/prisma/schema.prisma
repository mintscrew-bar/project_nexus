generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(cuid())
  email               String?            @unique
  emailVerified       Boolean            @default(false)
  password            String?
  username            String
  bio                 String?
  avatar              String?
  role                UserRole           @default(USER)
  reputation          Int                @default(100)
  isRestricted        Boolean            @default(false)
  restrictedUntil     DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  status              UserStatus         @default(OFFLINE)
  lastSeenAt          DateTime?
  reputationScore     Float?
  isBanned            Boolean            @default(false)
  banReason           String?
  bannedAt            DateTime?
  banUntil            DateTime?
  adminAuditLogs      AdminAuditLog[]    @relation("AdminAuditLogs")
  reviewedAppeals     Appeal[]           @relation("AppealReviewer")
  appeals             Appeal[]           @relation("UserAppeals")
  authProviders       AuthProvider[]
  chatMessages        ChatMessage[]
  clanActivityLogs    ClanActivityLog[]  @relation("ClanActivityActor")
  clanAnnouncements   ClanAnnouncement[] @relation("ClanAnnouncementAuthor")
  clanChatMessages    ClanChatMessage[]
  clanInvitesReceived ClanInvitation[]   @relation("ClanInvitee")
  clanInvitesSent     ClanInvitation[]   @relation("ClanInviter")
  clanMemberships     ClanMember[]
  clanRankings        ClanRanking[]
  ownedClans          Clan[]             @relation("ClanOwner")
  commentLikes        CommentLike[]
  comments            Comment[]
  receivedDMs         DirectMessage[]    @relation("ReceivedDMs")
  sentDMs             DirectMessage[]    @relation("SentDMs")
  friendOf            Friendship[]       @relation("FriendOfUser")
  friendships         Friendship[]       @relation("UserFriendships")
  matchParticipations MatchParticipant[]
  matchStatsCaches    MatchStatsCache[]
  nexusRanking        NexusRanking?
  notifications       Notification[]
  bookmarks           PostBookmark[]
  postLikes           PostLike[]
  postReports         PostReport[]       @relation("PostReportReporter")
  posts               Post[]
  riotAccounts        RiotAccount[]
  roomParticipations  RoomParticipant[]
  hostedRooms         Room[]             @relation("RoomHost")
  sessions            Session[]
  snakeDraftPicks     SnakeDraftPick[]
  teamMembers         TeamMember[]
  captainedTeams      Team[]             @relation("TeamCaptain")
  termsAgreements     TermsAgreement[]
  ratingsGiven        UserRating[]       @relation("RaterUser")
  ratingsReceived     UserRating[]       @relation("RatedUser")
  reportsSubmitted    UserReport[]       @relation("ReporterUser")
  reportsReceived     UserReport[]       @relation("ReportedUser")
  settings            UserSettings?
  statsRecomputeQueue StatsRecomputeQueue?
  votesGiven          MatchVote[]        @relation("VoterUser")
  votesReceived       MatchVote[]        @relation("VotedForUser")
  mvpMatches          Match[]            @relation("MatchMVP")
  aceMatches          Match[]            @relation("MatchACE")
  discordGuildLinks   DiscordGuildLink[] @relation("DiscordGuildLinkOwner")

  @@index([email])
  @@index([reputation])
  @@index([createdAt])
  @@index([isBanned])
  @@map("users")
}

model AuthProvider {
  id         String           @id @default(cuid())
  userId     String
  provider   AuthProviderType
  providerId String
  metadata   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("auth_providers")
}

model TermsAgreement {
  id               String   @id @default(cuid())
  userId           String
  termsOfService   Boolean  @default(false)
  privacyPolicy    Boolean  @default(false)
  ageVerification  Boolean  @default(false)
  marketingConsent Boolean  @default(false)
  agreedAt         DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("terms_agreements")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  notifyFriendRequest  Boolean  @default(true)
  notifyFriendAccepted Boolean  @default(true)
  notifyMatchStart     Boolean  @default(true)
  notifyMatchResult    Boolean  @default(true)
  notifyTeamInvite     Boolean  @default(true)
  notifyMention        Boolean  @default(true)
  notifyComment        Boolean  @default(true)
  notifyClanActivity   Boolean  @default(true)
  notifySystem         Boolean  @default(true)
  showOnlineStatus     Boolean  @default(true)
  showMatchHistory     Boolean  @default(true)
  showRiotAccounts     Boolean  @default(true)
  showChampionStats    Boolean  @default(true)
  allowFriendRequests  Boolean  @default(true)
  highlightChampionId  String?
  highlightStatType    String?
  theme                String   @default("dark")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model RiotAccount {
  id                  String               @id @default(cuid())
  userId              String
  puuid               String               @unique
  summonerId          String?
  gameName            String
  tagLine             String
  tier                String               @default("UNRANKED")
  rank                String               @default("")
  lp                  Int                  @default(0)
  // 솔로랭크 시즌 누적 승/패 (league-v4 entries에서 동기화)
  soloWins            Int                  @default(0)
  soloLosses          Int                  @default(0)
  // 자유랭크 5v5 현재값 + 시즌 누적 승/패
  flexTier            String               @default("UNRANKED")
  flexRank            String               @default("")
  flexLp              Int                  @default(0)
  flexWins            Int                  @default(0)
  flexLosses          Int                  @default(0)
  peakTier            String?
  peakRank            String?
  mainRole            Role?
  subRole             Role?
  isPrimary           Boolean              @default(false)
  verifiedAt          DateTime?
  lastSyncedAt        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  championPreferences ChampionPreference[]
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameName, tagLine])
  @@index([userId])
  @@index([puuid])
  @@map("riot_accounts")
}

model ChampionPreference {
  id            String      @id @default(cuid())
  riotAccountId String
  role          Role
  championId    String
  order         Int
  createdAt     DateTime    @default(now())
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id], onDelete: Cascade)

  @@unique([riotAccountId, role, championId])
  @@index([riotAccountId, role])
  @@map("champion_preferences")
}

model Room {
  id                String                @id @default(cuid())
  name              String
  hostId            String
  password          String?
  maxParticipants   Int                   @default(10)
  isPrivate         Boolean               @default(false)
  status            RoomStatus            @default(WAITING)
  teamMode          TeamMode              @default(SNAKE_DRAFT)
  allowSpectators   Boolean               @default(true)
  startingPoints    Int?
  minBidIncrement   Int?
  bidTimeLimit      Int?                  @default(30)
  pickTimeLimit     Int?                  @default(60)
  captainSelection  TeamCaptainSelection? @default(RANDOM)
  bracketFormat     BracketType?          @default(SINGLE_ELIMINATION)
  discordGuildId    String?
  discordCategoryId String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  chatMessages      ChatMessage[]
  matches           Match[]
  discordChannels   RoomDiscordChannel[]
  participants      RoomParticipant[]
  host              User                  @relation("RoomHost", fields: [hostId], references: [id])
  snakeDraftPicks   SnakeDraftPick[]
  teams             Team[]

  @@index([hostId])
  @@index([status])
  @@index([isPrivate])
  @@index([createdAt])
  @@map("rooms")
}

model RoomParticipant {
  id        String              @id @default(cuid())
  roomId    String
  userId    String
  role      RoomParticipantRole @default(PLAYER)
  isReady   Boolean             @default(false)
  isCaptain Boolean             @default(false)
  teamId    String?
  joinedAt  DateTime            @default(now())
  room      Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  team      Team?               @relation(fields: [teamId], references: [id])
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([teamId])
  @@index([roomId, isReady, role]) // 방 시작 대기 체크: WHERE roomId=X AND isReady=true AND role='PLAYER'
  @@map("room_participants")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String?
  roomName  String?
  userId    String
  content   String
  createdAt DateTime @default(now())
  room      Room?    @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@index([roomName])
  @@map("chat_messages")
}

model RoomDiscordChannel {
  id          String             @id @default(cuid())
  roomId      String
  channelId   String             @unique
  channelType DiscordChannelType
  teamName    String?
  createdAt   DateTime           @default(now())
  room        Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_discord_channels")
}

// 멀티 길드 지원: 넥서스 봇을 외부 디스코드 서버에 연동한 기록.
// guildId 1개당 1행(소유권/활성화 상태). Room.discordGuildId는 ACTIVE 링크에서 도출.
model DiscordGuildLink {
  id          String                 @id @default(cuid())
  guildId     String                 @unique
  guildName   String?
  ownerId     String
  clanId      String?
  status      DiscordGuildLinkStatus @default(PENDING)
  activatedAt DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  owner       User                   @relation("DiscordGuildLinkOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  clan        Clan?                  @relation(fields: [clanId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([clanId])
  @@index([status])
  @@map("discord_guild_links")
}

model Team {
  id                String             @id @default(cuid())
  roomId            String
  name              String
  captainId         String
  color             String?
  initialBudget     Int                @default(0)
  remainingBudget   Int                @default(0)
  hasReceivedBonus  Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auctionBids       AuctionBid[]
  matchParticipants MatchParticipant[]
  matchTeamStats    MatchTeamStats[]
  matchesAsTeamA    Match[]            @relation("TeamA")
  matchesAsTeamB    Match[]            @relation("TeamB")
  wonMatches        Match[]            @relation("MatchWinner")
  roomParticipants  RoomParticipant[]
  snakeDraftPicks   SnakeDraftPick[]
  members           TeamMember[]
  captain           User               @relation("TeamCaptain", fields: [captainId], references: [id])
  room              Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([captainId])
  @@map("teams")
}

model TeamMember {
  id           String   @id @default(cuid())
  teamId       String
  userId       String
  assignedRole Role?
  soldPrice    Int?
  pickOrder    Int?
  joinedAt     DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model SnakeDraftPick {
  id         String   @id @default(cuid())
  roomId     String
  teamId     String
  userId     String
  pickNumber Int
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([teamId])
  @@map("snake_draft_picks")
}

model AuctionBid {
  id           String   @id @default(cuid())
  roomId       String
  teamId       String
  targetUserId String
  amount       Int
  isYuchal     Boolean  @default(false)
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([teamId])
  @@index([targetUserId])
  @@index([targetUserId, createdAt]) // 사용자별 최근 입찰 내역 조회 최적화
  @@map("auction_bids")
}

model Match {
  id             String             @id @default(cuid())
  // 외부(랭크 캐시 인제스트) 매치의 경우 roomId는 NULL — Nexus 내부 토너먼트 매치만 roomId를 가진다.
  roomId         String?
  teamAId        String?
  teamBId        String?
  winnerId       String?
  // MVP: 이긴 팀 중 투표로 선정된 유저, ACE: 진 팀 중 투표로 선정된 유저
  mvpUserId      String?
  aceUserId      String?
  status         MatchStatus        @default(PENDING)
  matchNumber    Int?
  bracketRound   String?
  round          Int?
  bracketType    BracketType?
  tournamentCode String?
  riotMatchId    String?
  patchVersion   String?            // ex: "14.8" — 패치 임팩트 분석용
  // Riot 큐 식별자 (외부 인제스트 매치). 420=솔랭, 440=자랭, 400=일반 드래프트, 430=일반 블라인드, 450=ARAM.
  // 내부 토너먼트 매치는 NULL — roomId 기준으로 식별한다.
  queueId        Int?
  gameDuration   Int?
  dataCollected  Boolean            @default(false)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  participants   MatchParticipant[]
  teamStats      MatchTeamStats[]
  votes          MatchVote[]
  room           Room?              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  teamA          Team?              @relation("TeamA", fields: [teamAId], references: [id])
  teamB          Team?              @relation("TeamB", fields: [teamBId], references: [id])
  winner         Team?              @relation("MatchWinner", fields: [winnerId], references: [id])
  mvpUser        User?              @relation("MatchMVP", fields: [mvpUserId], references: [id])
  aceUser        User?              @relation("MatchACE", fields: [aceUserId], references: [id])
  ratings        UserRating[]
  reports        UserReport[]

  @@index([roomId])
  @@index([teamAId])
  @@index([teamBId])
  @@index([status])
  @@index([queueId])
  @@index([completedAt])
  @@map("matches")
}

model MatchVote {
  id          String    @id @default(cuid())
  matchId     String
  voterId     String    // 투표한 유저
  votedForId  String    // 투표 대상 유저
  voteType    VoteType  // MVP | ACE
  createdAt   DateTime  @default(now())

  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voter       User      @relation("VoterUser", fields: [voterId], references: [id], onDelete: Cascade)
  votedFor    User      @relation("VotedForUser", fields: [votedForId], references: [id], onDelete: Cascade)

  // 같은 매치에서 같은 타입 중복 투표 방지
  @@unique([matchId, voterId, voteType])
  @@index([matchId])
  @@map("match_votes")
}

model MatchParticipant {
  id                          String   @id @default(cuid())
  matchId                     String
  // 외부 랭크 캐시 인제스트 시 Nexus 유저로 매핑되지 않는 puuid는 userId가 NULL.
  userId                      String?
  // 외부 매치는 Nexus Team이 없으므로 teamId NULL — Riot 100/200 팀은 riotTeamId로 구분한다.
  teamId                      String?
  // Riot puuid (외부/내부 매치 공통 식별자) — 인제스트 멱등성과 외부 puuid 조회용.
  puuid                       String?
  // Riot 팀 번호 (100=블루, 200=레드). 외부 매치 head-to-head 비교 시 같은 팀/적팀 판단에 사용.
  riotTeamId                  Int?
  championId                  Int
  championName                String
  position                    String
  summoner1Id                 Int
  summoner2Id                 Int
  kills                       Int
  deaths                      Int
  assists                     Int
  totalMinionsKilled          Int
  neutralMinionsKilled        Int
  goldEarned                  Int
  goldSpent                   Int
  totalDamageDealt            Int
  totalDamageDealtToChampions Int
  totalDamageTaken            Int
  totalHeal                   Int
  damageSelfMitigated         Int
  visionScore                 Int
  wardsPlaced                 Int
  wardsKilled                 Int
  detectorWardsPlaced         Int
  item0                       Int
  item1                       Int
  item2                       Int
  item3                       Int
  item4                       Int
  item5                       Int
  item6                       Int
  item7                       Int?
  perks                       Json
  itemPurchaseOrder           Json?
  skillOrder                  Json?
  timelineExtractedAt         DateTime?
  champLevel                  Int
  largestKillingSpree         Int
  largestMultiKill            Int
  longestTimeSpentLiving      Int
  totalTimeSpentDead          Int
  turretKills                 Int
  inhibitorKills              Int
  dragonKills                 Int
  baronKills                  Int
  doubleKills                 Int
  tripleKills                 Int
  quadraKills                 Int
  pentaKills                  Int
  firstBloodKill              Boolean
  firstTowerKill              Boolean
  win                         Boolean
  createdAt                   DateTime @default(now())
  match                       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team                        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 인제스트 멱등성: 동일 매치 내 같은 puuid 중복 방지. (외부/내부 매치 공통)
  @@unique([matchId, puuid])
  @@index([matchId])
  @@index([userId])
  @@index([teamId])
  @@index([championId])
  @@index([puuid])
  @@map("match_participants")
}

model MatchTeamStats {
  id              String   @id @default(cuid())
  matchId         String
  teamId          String
  win             Boolean
  towerKills      Int
  inhibitorKills  Int
  baronKills      Int
  dragonKills     Int
  riftHeraldKills Int
  firstBlood      Boolean  @default(false)
  firstTower      Boolean  @default(false)
  firstBaron      Boolean  @default(false)
  firstDragon     Boolean  @default(false)
  bans            Json
  createdAt       DateTime @default(now())
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@index([matchId])
  @@index([teamId])
  @@map("match_team_stats")
}

model Clan {
  id            String             @id @default(cuid())
  name          String             @unique
  tag           String             @unique
  description   String?
  logo          String?
  ownerId       String
  isRecruiting  Boolean            @default(true)
  maxMembers    Int                @default(50)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  minTier       String?
  discord       String?
  officerCanManageSettings      Boolean @default(true)
  officerCanManageMembers       Boolean @default(true)
  officerCanManageAnnouncements Boolean @default(true)
  officerCanManageInvitations   Boolean @default(true)
  activityLogs  ClanActivityLog[]
  announcements ClanAnnouncement[]
  chatMessages  ClanChatMessage[]
  invitations   ClanInvitation[]
  members       ClanMember[]
  clanRankings  ClanRanking[]
  discordGuildLinks DiscordGuildLink[]
  owner         User               @relation("ClanOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([isRecruiting])
  @@map("clans")
}

model ClanMember {
  id       String   @id @default(cuid())
  clanId   String
  userId   String
  role     ClanRole @default(MEMBER)
  joinedAt DateTime @default(now())
  clan     Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
  @@map("clan_members")
}

model ClanChatMessage {
  id        String       @id @default(cuid())
  clanId    String
  userId    String
  content   String
  isDeleted Boolean      @default(false)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  clan      Clan         @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   UserReport[]

  @@index([clanId, createdAt])
  @@map("clan_chat_messages")
}

model ClanInvitation {
  id         String               @id @default(cuid())
  clanId     String
  inviterId  String
  inviteeId  String?
  type       ClanInvitationType
  status     ClanInvitationStatus @default(PENDING)
  inviteCode String?              @unique
  expiresAt  DateTime?
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime             @default(now())
  clan       Clan                 @relation(fields: [clanId], references: [id], onDelete: Cascade)
  invitee    User?                @relation("ClanInvitee", fields: [inviteeId], references: [id])
  inviter    User                 @relation("ClanInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([clanId, inviteeId, type, status])
  @@index([clanId, status])
  @@index([inviteeId, status])
  @@map("clan_invitations")
}

model ClanAnnouncement {
  id        String   @id @default(cuid())
  clanId    String
  authorId  String
  content   String
  isPinned  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("ClanAnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  clan      Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId, isPinned, createdAt])
  @@map("clan_announcements")
}

model ClanActivityLog {
  id        String           @id @default(cuid())
  clanId    String
  actorId   String?
  action    ClanActivityType
  targetId  String?
  details   Json?
  createdAt DateTime         @default(now())
  actor     User?            @relation("ClanActivityActor", fields: [actorId], references: [id])
  clan      Clan             @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId, createdAt])
  @@map("clan_activity_logs")
}

/// 동적 게시판: 관리자가 추가/수정/삭제할 수 있는 커뮤니티 게시판.
/// 기존 PostCategory enum을 대체하며, slug로 enum 값과 호환된다(notice/free/tip/qna).
model Board {
  id          String    @id @default(cuid())
  /// URL/식별용 슬러그 (소문자). 기본 게시판은 enum 값과 1:1 대응
  slug        String    @unique
  /// 표시 이름 (예: "자유")
  name        String
  /// 전체 이름 (예: "자유게시판"). 없으면 name 사용
  fullName    String?
  /// 게시판 설명
  description String?
  /// lucide 아이콘 이름 (예: "MessageCircle")
  iconName    String?
  /// Tailwind 색상 클래스 (예: "text-text-secondary")
  color       String?
  /// 정렬 순서 (작을수록 앞)
  order       Int       @default(0)
  /// 활성/비활성 (비활성 시 글쓰기·노출 제한)
  isActive    Boolean   @default(true)
  /// 일시 숨김 (목록에서 감추되 데이터 보존)
  isHidden    Boolean   @default(false)
  /// soft delete
  isDeleted   Boolean   @default(false)
  /// 글쓰기 최소 권한. null이면 모든 유저 작성 가능. 지정 시 해당 역할 이상만 작성
  writeRole   UserRole?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  posts       Post[]

  @@index([isDeleted, isHidden, isActive, order])
  @@map("boards")
}

model Post {
  id        String         @id @default(cuid())
  title     String
  content   String
  /// 레거시 카테고리 enum — boardId 도입 후 스냅샷/하위호환용으로 보존(nullable)
  category  PostCategory?
  /// 소속 게시판 FK. 게시판 삭제 시 글은 보존하기 위해 SetNull
  boardId   String?
  board     Board?         @relation(fields: [boardId], references: [id], onDelete: SetNull)
  authorId  String
  views     Int            @default(0)
  isPinned  Boolean        @default(false)
  isEdited  Boolean        @default(false)
  isDeleted Boolean        @default(false)
  isBlinded Boolean        @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  comments  Comment[]
  bookmarks PostBookmark[]
  likes     PostLike[]
  reports   PostReport[]
  tags      PostTag[]
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category, isPinned, createdAt])
  @@index([boardId, isPinned, createdAt])
  @@index([authorId])
  @@map("posts")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  posts     PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  isEdited  Boolean       @default(false)
  isDeleted Boolean       @default(false)
  isBlinded Boolean       @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  likes     CommentLike[]
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]     @relation("CommentReplies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports   PostReport[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

model PostBookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@map("post_bookmarks")
}

model PostReport {
  id           String           @id @default(cuid())
  reporterId   String
  postId       String?
  commentId    String?
  reason       PostReportReason
  description  String
  status       ReportStatus     @default(PENDING)
